{
  "name": "rerun-viewer",
  "displayName": "Rerun Viewer",
  "description": "View Rerun .rrd recordings directly in Visual Studio Code with full timeline, 3D, and multimodal data visualization",
  "version": "0.0.1",
  "publisher": "kamathsblog",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Data Science",
    "Other"
  ],
  "keywords": [
    "rerun",
    "visualization",
    "rrd",
    "robotics",
    "computer vision",
    "3d",
    "timeline",
    "multimodal",
    "data",
    "viewer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/adityakamath/rerun_vscode"
  },
  "bugs": {
    "url": "https://github.com/adityakamath/rerun_vscode/issues"
  },
  "homepage": "https://github.com/adityakamath/rerun_vscode#readme",
  "license": "MIT OR Apache-2.0",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rerun.openViewer",
        "title": "Rerun: Open Viewer",
        "category": "Rerun"
      }
    ],
    "customEditors": [
      {
        "viewType": "rerun.viewer",
        "displayName": "Rerun Viewer",
        "selector": [
          {
            "filenamePattern": "*.rrd"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run compile:webview",
    "compile": "tsc -p ./",
    "compile:webview": "node webview/build.mjs",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "esbuild": "^0.25.10",
    "eslint": "^8.x",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@rerun-io/web-viewer": "^0.25.1"
  }
}
